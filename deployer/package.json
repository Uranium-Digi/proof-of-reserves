{
    "name": "deployer",
    "version": "1.0.0",
    "main": "index.js",
    "license": "MIT",
    "dependencies": {
        "@aws-crypto/client-node": "^4.0.2",
        "@coral-xyz/anchor": "^0.30.1",
        "@grpc/grpc-js": "^1.12.2",
        "@grpc/proto-loader": "^0.7.13",
        "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
        "@metaplex-foundation/mpl-toolbox": "^0.10.0",
        "@metaplex-foundation/umi": "^1.2.0",
        "@metaplex-foundation/umi-bundle-defaults": "^1.2.0",
        "@metaplex-foundation/umi-uploader-irys": "^1.2.0",
        "@solana/spl-token": "^0.4.9",
        "@solana/web3.js": "^1.98.2",
        "bs58": "^6.0.0",
        "dotenv": "^16.4.5",
        "node-cron": "^3.0.3",
        "ts-proto": "^2.4.0",
        "tweetnacl": "^1.0.3"
    },
    "devDependencies": {
        "@babel/core": "^7.26.0",
        "@babel/preset-env": "^7.26.9",
        "@babel/preset-typescript": "^7.27.0",
        "@types/node-cron": "^3.0.11",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "babel-jest": "^29.7.0",
        "eslint": "^8.42.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "grpc_tools_node_protoc_ts": "^5.3.3",
        "grpc-tools": "^1.12.4",
        "jest": "^29.7.0",
        "prettier": "^3.0.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.2"
    },
    "scripts": {
        "dev": "ts-node src/index.ts",
        "start": "node dist/src/index.js",
        "build": "npm run build:proto && tsc",
        "test": "jest",
        "deploy": "ts-node scripts/deploy-por-wrap-uranium.ts",
        "build:proto": "npm run build:proto-ts && npm run build:proto-js",
        "build:proto-ts": "grpc_tools_node_protoc --plugin=protoc-gen-ts=./node_modules/.bin/protoc-gen-ts --ts_out=grpc_js:./src/protobuf -I ./protobuf ./protobuf/*.proto",
        "build:proto-js": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:./src/protobuf --grpc_out=grpc_js:./src/protobuf --plugin=protoc-gen-grpc=./node_modules/.bin/grpc_tools_node_protoc_plugin -I ./protobuf ./protobuf/*.proto"
    }
}
