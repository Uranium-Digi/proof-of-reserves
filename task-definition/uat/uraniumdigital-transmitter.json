{
  "family": "uat-uraniumdigital-transmitter-task-family",
  "containerDefinitions": [
    {
      "name": "uraniumdigital-transmitter-uat",
      "image": "image",
      "cpu": 512,
      "memory": 512,
      "portMappings": [],
      "essential": true,
      "environment": [
        {
          "name": "AWS_DEFAULT_REGION",
          "value": "us-east-1"
        },
        {
          "name": "RUST_LOG",
          "value": "debug"
        },
        {
          "name": "NO_COLOR",
          "value": "true"
        },
        {
          "name": "SECRET_NAME",
          "value": "uraniumdigital_transmitter/uat"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/uat-uraniumdigital-transmitter-task-family",
          "mode": "non-blocking",
          "awslogs-create-group": "true",
          "max-buffer-size": "25m",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "systemControls": []
    }
  ],
  "taskRoleArn": "arn:aws:iam::677276105478:role/ECSServiceRole",
  "executionRoleArn": "arn:aws:iam::677276105478:role/ECSServiceRole",
  "networkMode": "bridge",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": ["EC2"],
  "cpu": "512",
  "memory": "512",
  "enableFaultInjection": false
}
